GEMINI_API_KEY=
GEMINI_API_KEY_2=              # 2번째 계정 키(로테이션, 선택)
GEMINI_API_KEY_3=              # 3~5번째도 지원(선택)
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GROQ_API_KEY=

# 네이버 검색 API (블로그/뉴스 — 검색 권한 앱)
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# 네이버 데이터랩 (검색어트렌드 — 데이터랩 권한 앱)
NAVER_DATALAB_CLIENT_ID=
NAVER_DATALAB_CLIENT_SECRET=

# Instagram 수집 (기본 off — 메인 파이프라인과 격리)
INSTAGRAM_ENABLED=false

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── agents-slack (TF팀 멀티에이전트 Slack 논의 서비스) ──────────────
# 프로바이더 선택: auto|gemini|anthropic  (auto=무료 Gemini 우선, 없으면 Anthropic)
AGENT_PROVIDER=auto
# 무료 Gemini 주력 — 위 GEMINI_API_KEY(~_5)를 그대로 공유한다(별도 키 불필요). 최대 5개 로테이션.
AGENT_GEMINI_MODEL=gemini-2.5-flash        # 전문가 에이전트 모델
AGENT_GEMINI_SYNTH_MODEL=gemini-2.5-flash  # 신디사이저(종합) 모델
# Anthropic (옵션, 유료 — 명시적 opt-in일 때만)
ANTHROPIC_API_KEY=
AGENT_EXPERT_MODEL=claude-sonnet-5
AGENT_SYNTH_MODEL=claude-opus-4-8
AGENT_ROUNDS=2                        # 전문가 발언 라운드 수
# Slack 봇 (serve 모드 — Socket Mode)
SLACK_BOT_TOKEN=                      # xoxb-
SLACK_APP_TOKEN=                      # xapp- (Socket Mode)
SLACK_SIGNING_SECRET=
# MOCK_LLM=true                       # 키 없이 오케스트레이션/포맷 검증

# ── buzzAnalysis (화제성 분석 데일리 리포팅 — trendLeading 본체와 완전 격리된 별도 모듈) ──
# GEMINI_API_KEY(~_5), NAVER_SEARCH_*, NAVER_DATALAB_*, TELEGRAM_BOT_TOKEN은 위 값을 그대로 공유(읽기 전용).
BUZZ_TELEGRAM_CHAT_ID=                # 선택 — 미설정 시 TELEGRAM_CHAT_ID로 폴백 (같은 봇, 다른 챗으로 보내고 싶을 때만 설정)
BUZZ_X_ENABLED=false                  # X(트위터) 보조 수집 — 기본 off, 추후 슬라이스용
